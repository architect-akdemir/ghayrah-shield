{
  "manifest_version": 3,
  "name": "Ghayrah-Shield Kernel",
  "version": "0.1",
  "permissions": ["declarativeNetRequest", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Shield Active"
  }
}
